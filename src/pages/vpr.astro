        <!-- LIGHTBOX OVERLAY -->
        <div id="lightbox-overlay" aria-label="Zoomed Image Overlay">
            <button class="lightbox-close" id="lightbox-close-btn"
                >&times;</button
            >
            <img id="lightbox-image" src="" alt="" />
        </div>

        <!-- SPEAKER NOTES DRAWER -->
        <div id="notes-drawer">
            <div class="drawer-header">
                <span class="drawer-title">Speaker Script</span>
                <div style="display: flex; gap: 1rem; align-items: center;">
                    <button
                        id="edit-notes-btn"
                        style="background:none; border:none; color:var(--color-brand-blue); font-size:1rem; cursor:pointer; font-weight: 500;"
                        >✏️ Edit</button
                    >
                    <button
                        id="close-notes-btn"
                        style="background:none; border:none; color:var(--color-text); font-size:1.5rem; cursor:pointer; padding-bottom: 2px;"
                        >&times;</button
                    >
                </div>
            </div>
            <div class="notes-content" id="notes-text">
                <!-- Dynamic content injected here -->
            </div>
        </div>

        <!-- SLIDE INDEX DRAWER -->
        <div id="index-drawer">
            <div class="drawer-header" style="margin-bottom: 1rem;">
                <span
                    class="drawer-title"
                    style="color: var(--color-brand-teal);"
                    >Slide Index (S)</span
                >
                <button
                    id="close-index-btn"
                    style="background:none; border:none; color:var(--color-text); font-size:1.5rem; cursor:pointer;"
                    >×</button
                >
            </div>
            <div class="index-grid" id="index-grid-container">
                <!-- Dynamic items injected here -->
            </div>
        </div>

        <script define:vars={{ parsedNotes }}>
            // Speaker notes data injected from server
            let notes = parsedNotes;

            // Slide navigation controller logic
            let currentSlide = 0;
            const slides = document.querySelectorAll(".slide");
            const totalSlides = slides.length;
            const deck = document.getElementById("deck");
            const progressBar = document.getElementById("progress-bar");

            // Drawers
            const notesDrawer = document.getElementById("notes-drawer");
            const notesText = document.getElementById("notes-text");
            const closeNotesBtn = document.getElementById("close-notes-btn");
            const editNotesBtn = document.getElementById("edit-notes-btn");
            let isEditingNotes = false;

            async function saveCurrentNotes() {
                isEditingNotes = false;
                notesText.contentEditable = "false";
                notesText.style.outline = "none";
                notesText.style.padding = "0";
                editNotesBtn.innerText = "✏️ Edit";

                // Update local array
                notes[currentSlide] = notesText.innerHTML;

                // Save to API
                try {
                    const res = await fetch("/api/save-notes", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ notes }),
                    });
                    if (res.ok) {
                        editNotesBtn.innerText = "✅ Saved!";
                        setTimeout(() => {
                            if (!isEditingNotes)
                                editNotesBtn.innerText = "✏️ Edit";
                        }, 2000);
                    } else {
                        editNotesBtn.innerText = "❌ Error";
                        setTimeout(() => {
                            if (!isEditingNotes)
                                editNotesBtn.innerText = "✏️ Edit";
                        }, 2000);
                    }
                } catch (e) {
                    console.error(e);
                    editNotesBtn.innerText = "❌ Error";
                    setTimeout(() => {
                        if (!isEditingNotes) editNotesBtn.innerText = "✏️ Edit";
                    }, 2000);
                }
            }

            function cancelEditingNotes() {
                isEditingNotes = false;
                notesText.contentEditable = "false";
                notesText.style.outline = "none";
                notesText.style.padding = "0";
                editNotesBtn.innerText = "✏️ Edit";
                // Restore original content
                notesText.innerHTML =
                    notes[currentSlide] || "No speaker notes for this slide.";
            }

            editNotesBtn.addEventListener("click", async () => {
                if (!isEditingNotes) {
                    // Enter edit mode
                    isEditingNotes = true;
                    notesText.contentEditable = "true";
                    notesText.focus();
                    notesText.style.outline =
                        "2px solid var(--color-brand-blue)";
                    notesText.style.padding = "0.5rem";
                    editNotesBtn.innerText = "💾 Save";
                } else {
                    await saveCurrentNotes();
                }
            });

            notesText.addEventListener("keydown", async (e) => {
                if (!isEditingNotes) return;

                if (e.key === "Escape") {
                    e.preventDefault();
                    cancelEditingNotes();
                } else if (
                    (e.ctrlKey || e.metaKey) &&
                    e.key.toLowerCase() === "s"
                ) {
                    e.preventDefault();
                    await saveCurrentNotes();
                } else if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
                    e.preventDefault();
                    await saveCurrentNotes();
                }
            });

            const indexDrawer = document.getElementById("index-drawer");
            const closeIndexBtn = document.getElementById("close-index-btn");
            const indexContainer = document.getElementById(
                "index-grid-container"
            );

            // Initialize drawers content
            function initIndex() {
                indexContainer.innerHTML = "";
                slides.forEach((slide, idx) => {
                    let titleText = "Slide " + (idx + 1);
                    const titleEl = slide.querySelector(".slide-title");
                    const titleLayoutMain = slide.querySelector(".title-main");

                    if (titleEl) titleText = titleEl.innerText;
                    else if (titleLayoutMain)
                        titleText = titleLayoutMain.innerText;

                    const item = document.createElement("div");
                    item.className =
                        "index-item " + (idx === currentSlide ? "active" : "");
                    item.innerHTML =
                        `
                    <span class="index-num">Slide ` +
                        (idx + 1) +
                        `</span>
                    <h4 class="index-title">` +
                        titleText +
                        `</h4>
                `;
                    item.addEventListener("click", () => {
                        goToSlide(idx);
                        indexDrawer.classList.remove("open");
                    });
                    indexContainer.appendChild(item);
                });
            }

            function updateSlide() {
                deck.style.transform =
                    "translateX(-" + currentSlide * 100 + "vw)";

                // Update progress indicators
                const progressPct = ((currentSlide + 1) / totalSlides) * 100;
                progressBar.style.width = progressPct + "%";

                // Inject notes for current slide
                notesText.innerHTML =
                    notes[currentSlide] || "No speaker notes for this slide.";

                // Re-draw active slide in index
                const indexItems = document.querySelectorAll(".index-item");
                indexItems.forEach((item, idx) => {
                    if (idx === currentSlide) item.classList.add("active");
                    else item.classList.remove("active");
                });

                // Update footer counters
                document.querySelectorAll(".slide").forEach((slide, idx) => {
                    const counter = slide.querySelector(
                        ".slide-footer span:last-child"
                    );
                    if (counter)
                        counter.innerText =
                            "Slide " +
                            (currentSlide + 1) +
                            " of " +
                            totalSlides;
                });
            }

            function goToSlide(idx) {
                if (idx >= 0 && idx < totalSlides) {
                    currentSlide = idx;
                    updateSlide();
                }
            }

            function nextSlide() {
                if (currentSlide < totalSlides - 1) {
                    currentSlide++;
                    updateSlide();
                }
            }

            function prevSlide() {
                if (currentSlide > 0) {
                    currentSlide--;
                    updateSlide();
                }
            }

            // Navigation controls listeners
            document
                .getElementById("next-btn")
                .addEventListener("click", nextSlide);
            document
                .getElementById("prev-btn")
                .addEventListener("click", prevSlide);

            // Key bindings
            window.addEventListener("keydown", (e) => {
                // Ignore shortcut keys when typing inside editable fields or inputs
                if (
                    document.activeElement &&
                    (document.activeElement.isContentEditable ||
                        document.activeElement.tagName === "INPUT" ||
                        document.activeElement.tagName === "TEXTAREA")
                ) {
                    return;
                }

                if (
                    e.key === "ArrowRight" ||
                    e.key === " " ||
                    e.key === "PageDown" ||
                    e.key === "ArrowDown"
                ) {
                    e.preventDefault();
                    nextSlide();
                } else if (
                    e.key === "ArrowLeft" ||
                    e.key === "Backspace" ||
                    e.key === "PageUp" ||
                    e.key === "ArrowUp"
                ) {
                    e.preventDefault();
                    prevSlide();
                } else if (e.key === "Escape") {
                    closeLightbox();
                } else if (e.key.toLowerCase() === "n") {
                    notesDrawer.classList.toggle("open");
                } else if (e.key.toLowerCase() === "s") {
                    indexDrawer.classList.toggle("open");
                    if (indexDrawer.classList.contains("open")) {
                        // Center active slide item in horizontal scroll
                        setTimeout(() => {
                            const activeItem =
                                document.querySelector(".index-item.active");
                            if (activeItem)
                                activeItem.scrollIntoView({
                                    behavior: "smooth",
                                    block: "nearest",
                                    inline: "center",
                                });
                        }, 100);
                    }
                } else if (e.key.toLowerCase() === "a") {
                    const nav = document.querySelector(".nav-overlay");
                    if (nav) nav.classList.toggle("visible");
                }
            });

            // Toggle drawers on click
            closeNotesBtn.addEventListener("click", () =>
                notesDrawer.classList.remove("open")
            );
            closeIndexBtn.addEventListener("click", () =>
                indexDrawer.classList.remove("open")
            );

            // Initialize slide layout
            initIndex();
            updateSlide();

            // Lightbox Overlay logic
            const lightboxOverlay = document.getElementById("lightbox-overlay");
            const lightboxImage = document.getElementById("lightbox-image");
            const closeLightboxBtn =
                document.getElementById("lightbox-close-btn");

            // Add click listener to all images inside slides
            document.querySelectorAll(".slide img").forEach((img) => {
                img.style.cursor = "zoom-in";
                img.setAttribute("tabindex", "0");
                img.setAttribute("role", "button");
                img.setAttribute("aria-label", "Click to enlarge image");

                const openLightbox = (src, alt) => {
                    lightboxImage.src = src;
                    lightboxImage.alt = alt || "Enlarged image view";
                    lightboxOverlay.classList.add("open");
                };

                img.addEventListener("click", (e) => {
                    const target = e.target;
                    openLightbox(
                        target.getAttribute("src"),
                        target.getAttribute("alt")
                    );
                });
                img.addEventListener("keydown", (e) => {
                    if (e.key === "Enter" || e.key === " ") {
                        e.preventDefault();
                        const target = e.target;
                        openLightbox(
                            target.getAttribute("src"),
                            target.getAttribute("alt")
                        );
                    }
                });
            });

            function closeLightbox() {
                lightboxOverlay.classList.remove("open");
                setTimeout(() => {
                    lightboxImage.src = "";
                    lightboxImage.alt = "";
                }, 300);
            }

            // Close on clicking close button or background
            closeLightboxBtn.addEventListener("click", closeLightbox);
            lightboxOverlay.addEventListener("click", (e) => {
                if (e.target === lightboxOverlay) {
                    closeLightbox();
                }
            });
        </script>
    </body>
</html>
