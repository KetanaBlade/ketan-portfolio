---
import { Image } from 'astro:assets';
import headshot from '../assets/ketan-headshot.jpg';
import pagespeed from '../assets/pagespeed-100.jpg';

// Project 1 Assets
import onboardingDashboard from '../assets/work/fs-onboarding-dashboard.png';
import tasksBefore from '../assets/work/fs-tasks-grid-before.png';
import tasksAfter from '../assets/work/fs-tasks-grid-after.png';
import workflowConfigured from '../assets/work/studio-workflow-configured.jpg';
import workflowConfiguring from '../assets/work/studio-workflow-configuring.jpg';
import automationCardSort from '../assets/work/studio-automation-card-sort.jpg';
import studioAutomationList from '../assets/work/studio-automation-list.png';
import studioAutomationConfig from '../assets/work/studio-automation-config.png';
import studioFormsList from '../assets/work/studio-forms-list.png';
import studioFormsBuilder from '../assets/work/studio-forms-builder.png';
import studioFormsAi from '../assets/work/studio-forms-ai.png';
import caseRecord from '../assets/work/workspace-case-record.jpg';
import workspaceExperienceMain from '../assets/work/workspace-experience-main.jpg';
import workspaceAiChat from '../assets/work/workspace-ai-chat.jpg';
import workspaceAiComments from '../assets/work/workspace-ai-comments.jpg';
import workspaceAiDocs from '../assets/work/workspace-ai-docs.png';
import workspacePortalHome from '../assets/work/workspace-portal-home.jpg';
import workspacePortalDashboard from '../assets/work/workspace-portal-dashboard.jpg';
import workspacePortalSummary from '../assets/work/workspace-portal-summary.jpg';
import citizenFlows from '../assets/work/workspace-citizen-flows.jpg';
import brandA from '../assets/work/brand-a.png';
import brandB from '../assets/work/brand-b.png';
import semanticMapping from '../assets/work/semantic-mapping.svg';

// Project 2 Assets
import sailOverview from '../assets/work/leadership-figma-library.jpg';
import growthImage from '../assets/work/leadership-growth.svg';
import workshopImage from '../assets/work/leadership-community-v2.svg';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ketan Pandya — Portfolio Review</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-bg: #f8fafc;
            --color-surface: #ffffff;
            --color-surface-glass: rgba(255, 255, 255, 0.85);
            --color-border: rgba(15, 23, 42, 0.08);
            --color-border-hover: rgba(15, 23, 42, 0.16);
            --color-text: #0f172a;
            --color-text-muted: #334155; /* Refined Slate-700 dark gray: pairs with weight 500 for a stunning 8.4:1 contrast ratio */
            --color-brand-blue: #0369a1;
            --color-brand-teal: #0f766e;
            --color-accent: #4f46e5;
            
            --font-display: 'Outfit', 'Plus Jakarta Sans', system-ui, sans-serif;
            --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: var(--color-bg);
            font-family: var(--font-body);
            color: var(--color-text);
            font-weight: 500; /* Set default to 500 (Medium) so body text doesn't look thin */
            -webkit-font-smoothing: antialiased;
        }

        /* Background grid and glows */
        .ambient-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            overflow: hidden;
            pointer-events: none;
        }
        .glow-1 {
            position: absolute;
            top: -20%;
            right: -10%;
            width: 60%;
            height: 60%;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.04) 0%, rgba(0,0,0,0) 70%);
            filter: blur(80px);
        }
        .glow-2 {
            position: absolute;
            bottom: -20%;
            left: -10%;
            width: 60%;
            height: 60%;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(45, 212, 191, 0.03) 0%, rgba(0,0,0,0) 70%);
            filter: blur(80px);
        }
        
        /* Main deck container */
        #deck {
            position: relative;
            width: 100vw;
            height: 100vh;
            z-index: 10;
            display: flex;
            flex-direction: row;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            will-change: transform;
        }

        .slide {
            flex-shrink: 0;
            width: 100vw;
            height: 100vh;
            box-sizing: border-box;
            padding: 4rem 6rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        /* Slide header */
        .slide-header {
            display: flex;
            flex-direction: row-reverse;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--color-border);
            padding-bottom: 1.25rem;
            margin-bottom: 1.5rem;
            width: 100%;
        }
        .slide-meta {
            font-size: 0.85rem;
            color: var(--color-brand-blue);
            font-family: var(--font-display);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            font-weight: 600;
        }
        .slide-title {
            font-family: var(--font-display);
            font-size: 2.25rem;
            font-weight: 700;
            color: var(--color-text);
            margin: 0;
            letter-spacing: -0.01em;
        }
        .slide-header .slide-title {
            display: inline-flex;
            align-items: center;
        }

        /* Responsive Layouts */
        @media (max-width: 1024px) {
            .slide { padding: 2.5rem; }
            .slide-body { flex-direction: column; gap: 2rem; align-items: flex-start; height: auto; margin-top: 1rem; overflow-y: auto; }
            .col-text, .col-media { width: 100%; }
            .slide-header { flex-direction: column-reverse; align-items: flex-start; gap: 0.5rem; }
            .slide-title { font-size: 1.8rem; }
        }
        @media (max-width: 768px) {
            .slide { padding: 1.5rem; }
            .slide-title { font-size: 1.5rem; }
        }

        /* Slide Content layouts */
        .slide-body {
            flex-grow: 1;
            display: flex;
            gap: 4rem;
            align-items: center;
            height: calc(100% - 11rem);
        }
        
        .col-text {
            flex: 1;
            max-width: 50%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        .col-media {
            flex: 1;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .col-media.grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            align-items: center;
        }

        .col-media.grid-3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1rem;
            align-items: center;
        }

        .media-container {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            box-sizing: border-box;
        }

        .media-caption {
            font-size: 0.85rem;
            color: var(--color-text-muted);
            margin-top: 0.75rem;
            font-family: var(--font-body);
            text-align: center;
        }

        img {
            max-width: 100%;
            max-height: calc(100% - 2.5rem);
            height: auto;
            width: auto;
            object-fit: contain;
            border-radius: 8px;
        }

        /* Bullet points styling */
        ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        li {
            position: relative;
            padding-left: 2rem;
            font-size: 1.2rem;
            line-height: 1.6;
            color: var(--color-text-muted); /* Dark gray for secondary bullet text */
            font-weight: 500; /* Robust Medium weight for optimal legibility */
        }

        li strong {
            color: var(--color-text); /* Slate-900 accessible black for key introductory phrase */
            font-weight: 700; /* Bold weight for the introductory phrase to keep strong hierarchy */
        }

        li::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0.65rem;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--color-brand-blue);
            box-shadow: 0 0 8px var(--color-brand-blue);
        }

        li.highlight-li::before {
            background-color: var(--color-brand-teal);
            box-shadow: 0 0 8px var(--color-brand-teal);
        }

        /* Big callouts and metrics */
        .metric-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }
        .metric-card {
            background: var(--color-surface-glass);
            border: 1px solid var(--color-border);
            padding: 1.5rem;
            border-radius: 12px;
            text-align: center;
            backdrop-filter: blur(12px);
        }
        .metric-val {
            font-family: var(--font-display);
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-teal));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.25rem;
        }
        .metric-lbl {
            font-size: 0.95rem;
            color: var(--color-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Slide footer */
        .slide-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--color-border);
            padding-top: 1.25rem;
            font-size: 0.8rem;
            color: var(--color-text-muted);
            font-family: var(--font-display);
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        /* Layout modifications for Title Slide */
        .slide-title-layout {
            justify-content: center;
            align-items: center;
            padding: 4rem 10rem;
        }
        .title-container {
            text-align: center;
            max-width: 800px;
        }
        .title-pre {
            font-family: var(--font-display);
            font-size: 1rem;
            color: var(--color-brand-blue);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }
        .title-main {
            font-family: var(--font-display);
            font-size: 5.5rem;
            font-weight: 800;
            line-height: 1.05;
            color: var(--color-text);
            margin: 0 0 1.5rem 0;
            letter-spacing: -0.03em;
            background: linear-gradient(to right, #0f172a, #475569);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .title-sub {
            font-size: 1.8rem;
            color: var(--color-text-muted);
            font-weight: 300;
            margin-bottom: 3rem;
            line-height: 1.4;
        }
        .title-footer {
            margin-top: 4rem;
            font-family: var(--font-display);
            font-size: 0.9rem;
            letter-spacing: 0.15em;
            color: var(--color-brand-teal);
            text-transform: uppercase;
            font-weight: 600;
        }

        /* On-screen navigation layout */
        .nav-overlay {
            position: fixed;
            bottom: 2rem;
            right: 4rem;
            display: flex;
            gap: 1rem;
            z-index: 100;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        .nav-overlay.visible {
            opacity: 1;
            pointer-events: auto;
        }
        .nav-btn {
            background: var(--color-surface-glass);
            border: 1px solid var(--color-border);
            color: var(--color-text);
            width: 3.5rem;
            height: 3.5rem;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            backdrop-filter: blur(12px);
            transition: all 0.3s ease;
        }
        .nav-btn:hover {
            border-color: var(--color-brand-blue);
            background: rgba(56, 189, 248, 0.1);
            transform: translateY(-2px);
        }

        /* Speaker notes side drawer drawer styles */
        #notes-drawer {
            position: fixed;
            top: 0;
            right: -450px;
            width: 450px;
            height: 100vh;
            background: #ffffff;
            border-left: 1px solid var(--color-border);
            z-index: 200;
            box-shadow: -20px 0 40px rgba(15, 23, 42, 0.05);
            transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-sizing: border-box;
            padding: 3rem 2.5rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        #notes-drawer.open {
            right: 0;
        }
        .drawer-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            border-bottom: 1px solid var(--color-border);
            padding-bottom: 1rem;
        }
        .drawer-title {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--color-brand-blue);
        }
        .notes-content {
            font-family: var(--font-body);
            font-size: 1.1rem;
            line-height: 1.7;
            color: var(--color-text-muted);
        }
        .notes-content strong {
            color: var(--color-text);
        }

        /* Slide Index interactive drawer */
        #index-drawer {
            position: fixed;
            bottom: -320px;
            left: 0;
            width: 100vw;
            height: 320px;
            background: #ffffff;
            border-top: 1px solid var(--color-border);
            z-index: 150;
            box-shadow: 0 -20px 40px rgba(15, 23, 42, 0.05);
            transition: bottom 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-sizing: border-box;
            padding: 2.5rem 4rem;
            overflow-x: auto;
        }
        #index-drawer.open {
            bottom: 0;
        }
        .index-grid {
            display: flex;
            gap: 1.5rem;
            height: 180px;
            padding-top: 0.5rem;
        }
        .index-item {
            flex: 0 0 220px;
            height: 140px;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: 8px;
            padding: 1rem;
            box-sizing: border-box;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .index-item:hover {
            border-color: var(--color-brand-blue);
            background: rgba(56, 189, 248, 0.05);
            transform: translateY(-4px);
        }
        .index-item.active {
            border-color: var(--color-brand-teal);
            background: rgba(45, 212, 191, 0.08);
        }
        .index-num {
            font-family: var(--font-display);
            font-size: 0.8rem;
            color: var(--color-brand-blue);
            font-weight: 600;
        }
        .index-title {
            font-family: var(--font-display);
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--color-text);
            margin: 0.5rem 0;
            line-height: 1.3;
        }

        /* Top Progress Bar indicator */
        .progress-indicator {
            position: fixed;
            top: 0;
            left: 0;
            height: 4px;
            background: linear-gradient(to right, var(--color-brand-blue), var(--color-brand-teal));
            z-index: 1000;
            transition: width 0.3s ease;
        }

        /* Image Lightbox Overlay Modal */
        #lightbox-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(3, 7, 18, 0.95);
            z-index: 2000;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            backdrop-filter: blur(16px);
        }
        #lightbox-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }
        #lightbox-image {
            max-width: 90%;
            max-height: 90%;
            border-radius: 8px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transform: scale(0.95);
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        #lightbox-overlay.open #lightbox-image {
            transform: scale(1);
        }
        .lightbox-close {
            position: absolute;
            top: 2rem;
            right: 2rem;
            background: none;
            border: none;
            color: #ffffff;
            font-size: 2.5rem;
            cursor: pointer;
            opacity: 0.7;
            transition: opacity 0.2s ease;
        }
        .lightbox-close:hover {
            opacity: 1;
        }
        .slide img {
            cursor: zoom-in;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .slide img:hover {
            transform: scale(1.02);
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
        }
    </style>
</head>
<body>

    <div class="progress-indicator" id="progress-bar"></div>

    <div class="ambient-bg">
        <div class="glow-1"></div>
        <div class="glow-2"></div>
    </div>

    <!-- Floating Nav Overlay -->
    <div class="nav-overlay">
        <button class="nav-btn" id="prev-btn" aria-label="Previous Slide">←</button>
        <button class="nav-btn" id="next-btn" aria-label="Next Slide">→</button>
    </div>

    <!-- Slides Deck wrapper -->
    <div id="deck">

        <!-- Slide 1: Title -->
        <section class="slide slide-title-layout">
            <div class="title-container">
                <div class="title-pre">Portfolio Review</div>
                <h1 class="title-main">Ketan Pandya</h1>
                <div class="title-sub">Product Designer specializing in complex systems, evidence-based design, and systematic scaling.</div>
                <div class="title-footer">Capital One Virtual Portfolio Review</div>
            </div>
        </section>

        <!-- Slide 2: About Me & My Approach -->
        <section class="slide">
            <div class="slide-header">
                <span class="slide-meta">Introduction</span>
                <h2 class="slide-title">About Me & My Approach</h2>
            </div>
            <div class="slide-body">
                <div class="col-text">
                    <ul>
                        <li><strong>Education & Background:</strong> M.S. in Information Science from UNC Chapel Hill (specializing in HCI) and a B.A. in Philosophy from Virginia Tech.</li>
                        <li><strong>Personal Hobbies:</strong> You can usually find me hiking, traveling, reading, or diving down Wikipedia rabbit holes. I love learning about different perspectives.</li>
                        <li><strong>Evidence-Based Design:</strong> I believe the best design decisions are justified. I use data and user insights to validate where a design is going.</li>
                        <li><strong>Problem Solver:</strong> I look beyond the immediate feature request to understand the whole context and fix the actual root cause.</li>
                        <li><strong>Purposeful Craft:</strong> I believe that robust architecture and accessibility (WCAG 2.1 AA) are essential to making a product feel complete.</li>
                    </ul>
                </div>
                <div class="col-media">
                    <div class="media-container" style="max-width: 420px; aspect-ratio: 3/4;">
                        <Image src={headshot} alt="Ketan Pandya headshot" />
                        <span class="media-caption">Product Designer</span>
                    </div>
                </div>
            </div>
            <div class="slide-footer">
                <span>Ketan Pandya | Portfolio Review</span>

                <span>Slide 2 of 20</span>
            </div>
        </section>

        <!-- Slide 3: Agenda -->
        <section class="slide">
            <div class="slide-header">
                <span class="slide-meta">Introduction</span>
                <h2 class="slide-title">Agenda</h2>
            </div>
            <div class="slide-body">
                <div class="col-text">
                    <ul style="gap: 2rem;">
                        <li>
                            <strong>Project 1: Case Management Studio</strong>
                            <p style="margin: 0.5rem 0 0 0; font-size: 1.05rem; color: var(--color-text-muted);">Designing a flexible, visual platform that gives business admins no-code control while providing low-code developers with an extensible, modular object foundation.</p>
                        </li>
                        <li>
                            <strong>Project 2: Figma SAIL Component Library</strong>
                            <p style="margin: 0.5rem 0 0 0; font-size: 1.05rem; color: var(--color-text-muted);">Leading the end-to-end migration from Sketch to Figma, implementing 1:1 component-to-code parity, setting up strict library governance, and accelerating with Figma MCP.</p>
                        </li>
                        <li>
                            <strong>Q&A & Discussion</strong>
                            <p style="margin: 0.5rem 0 0 0; font-size: 1.05rem; color: var(--color-text-muted);">Dedicated Q&A checkpoints following both the Case Management Studio case study and the Figma SAIL migration presentation.</p>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="slide-footer">
                <span>Ketan Pandya | Portfolio Review</span>
                <span>Slide 3 of 20</span>
            </div>
        </section>

        <!-- Slide 4: Core Concepts -->
        <section class="slide">
            <div class="slide-header">
                <span class="slide-meta">Project 1: Case Management Studio</span>
                <h2 class="slide-title">Core Concepts: Cases, Workflows, & Tasks</h2>
            </div>
            <div class="slide-body">
                <div class="col-text">
                    <ul>
                        <li><strong>What is a "Case"?</strong> A generic term for any business lifecycle or process. For a city government, this is a <em>Permit Request</em>. For a university, it is a student's <em>Major</em>.</li>
                        <li><strong>What is a "Workflow"?</strong> The sequential tree of tasks and requirements to complete a case. For a permit, this is <em>Doc Upload → Inspection → Legal Review</em>. For a university major, this is the <em>Course Dependency Tree</em>.</li>
                        <li><strong>What is a "Task"?</strong> An individual, auditable unit of work assigned to a user or system (e.g., 'Submit Transcript' or 'Run Document Check').</li>
                        <li><strong>The Platform Strategy:</strong> Build a flexible layout engine capable of representing any of these diverse industry workflows out of the box.</li>
                    </ul>
                </div>
                <div class="col-media">
                    <div class="media-container" style="max-height: 85%;">
                        <Image src={semanticMapping} alt="Semantic Customization diagram" />
                        <span class="media-caption">How generic core concepts map to client-specific terminology</span>
                    </div>
                </div>
            </div>
            <div class="slide-footer">
                <span>Case Management Studio</span>
                <span>Slide 4 of 20</span>
            </div>
        </section>

        <!-- Slide 5: Monolithic Trap vs. Modularity -->
        <section class="slide">
            <div class="slide-header">
                <span class="slide-meta">Project 1: Case Management Studio</span>
                <h2 class="slide-title">The Challenge: Customizing Monolithic Solutions</h2>
            </div>
            <div class="slide-body">
                <div class="col-text">
                    <ul>
                        <li><strong>Sprawling Monolithic Codebases:</strong> Previous pre-built solutions were sprawling monoliths. Customers had to import the entire, massive codebase of intertwined objects even if they only needed a single feature. This made customizations and product upgrades a nightmare.</li>
                        <li><strong>No-Code Admin Controls:</strong> Establish a visual, visual builder where non-technical admins can configure their own case types, tasks, automation, and branding.</li>
                        <li><strong>Low-Code Extensible Architecture:</strong> Under the hood, build a decoupled, highly modular structure of Appian OOTB objects (interfaces, record types) that developers can extend.</li>
                        <li><strong>Modular Design Strategy:</strong> Create a system simple enough for business admins to build apps, but organized enough for developers to open in Appian Designer and extend later.</li>
                    </ul>
                </div>
